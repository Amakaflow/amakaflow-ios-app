  "info": {
    "description": "Mobile Backend-for-Frontend (AMA-1819 + AMA-1827). Thin proxy for the mobile-facing endpoints under /v1/. iOS calls this service exclusively for workout/sync/coach/chat/knowledge/nutrition flows so internal upstream renames don't require an iOS release.",
    "title": "AmakaFlow Mobile BFF",
    "version": "0.2.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Health probe \u2014 used by Render and any load balancer in front.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/v1/chat/stream": {
      "post": {
        "description": "iOS ChatStreamService \u2192 chat-api POST /chat/stream (SSE).\n\nUses `_proxy_stream` so chunks reach iOS as the LLM produces them;\nthe standard buffered proxy would defeat SSE.",
        "operationId": "v1_chat_stream_v1_chat_stream_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "V1 Chat Stream"
      }
    },
    "/v1/coach/fatigue-advice": {
      "post": {
        "description": "iOS getFatigueAdvice \u2192 chat-api POST /coach/fatigue-advice.",
        "operationId": "v1_coach_fatigue_advice_v1_coach_fatigue_advice_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "V1 Coach Fatigue Advice"
      }
    },
    "/v1/coach/memories": {
      "get": {
        "description": "iOS fetchCoachMemories \u2192 chat-api GET /coach/memories.",
