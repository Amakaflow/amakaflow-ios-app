      "WorkoutCompletionRequest": {
        "description": "Request body for POST /v1/workouts/complete.\n\nMirrors `WorkoutCompletionRequest` in mapper-api\n(services/mapper-api/backend/workout_completions.py) 1:1.\n\nNote: `execution_log`, `heart_rate_samples`, `workout_structure`,\n`intervals`, and `device_info` stay as free-form dicts here \u2014 the\nupstream model deliberately uses `Dict[str, Any]` after the AMA-1813\nsaga (the strict ExecutionLog tree rejected the iOS payload). We do\nNOT narrow these in v1; that's reserved for a future contract ticket.",
        "properties": {
          "client_generated_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Idempotency key \u2014 same value on every retry of the same logical completion.",
            "title": "Client Generated Id"
          },
          "device_info": {
            "anyOf": [
